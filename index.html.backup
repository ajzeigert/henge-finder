<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Henge Finder</title>
  
  <link rel="stylesheet" href="https://js.arcgis.com/4.33/esri/themes/light/main.css" />
  <script src="https://js.arcgis.com/4.33/"></script>
  
  <style>
    * { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; padding: 0; font-family: "Courier New", monospace; background: #1a1a2e; }
    #viewDiv { height: 100%; width: 100%; }
    
    .control-panel {
      position: absolute;
      top: 20px;
      right: 20px;
      width: 320px;
      background: rgba(20, 20, 35, 0.9);
      backdrop-filter: blur(12px);
      border-radius: 12px;
      padding: 24px;
      color: #f1faee;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(244, 162, 97, 0.2);
      z-index: 1000;
    }
    
    .panel-title { font-size: 18px; font-weight: bold; color: #f4a261; margin: 0 0 20px 0; text-align: center; text-transform: uppercase; letter-spacing: 2px; }
    
    .info-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding: 8px 0; border-bottom: 1px solid rgba(168, 218, 220, 0.2); }
    
    .info-label { font-size: 12px; color: #a8dadc; text-transform: uppercase; letter-spacing: 1px; }
    
    .info-value { font-size: 14px; color: #f1faee; font-weight: bold; }
    
    .slider-container { margin-top: 20px; }
    
    .slider-label { font-size: 12px; color: #a8dadc; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; display: block; }
    
    .date-display { text-align: center; font-size: 16px; color: #e9c46a; margin-bottom: 12px; font-weight: bold; }
    
    input[type="range"] {
      width: 100%;
      height: 8px;
      border-radius: 4px;
      background: linear-gradient(90deg, #264653, #2a9d8f, #e9c46a, #f4a261, #e76f51);
      outline: none;
      -webkit-appearance: none;
      cursor: pointer;
    }
    
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #f1faee;
      border: 3px solid #f4a261;
      cursor: pointer;
    }
    
    .instruction { font-size: 11px; color: #a8dadc; text-align: center; margin-top: 16px; opacity: 0.8; }
    
    .compass { display: flex; justify-content: center; gap: 8px; margin-top: 8px; }
    
    .compass-dir { padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; transition: all 0.3s ease; }
    
    .compass-dir.active { background: #f4a261; color: #1a1a2e; }
    
    .compass-dir:not(.active) { background: rgba(168, 218, 220, 0.2); color: #a8dadc; }
    
    .legend { display: flex; justify-content: center; gap: 20px; margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(168, 218, 220, 0.2); }
    
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; }
    
    .legend-color { width: 16px; height: 3px; border-radius: 1px; }
    
    .legend-sunset .legend-color { background: #e76f51; }
    
    .legend-sunrise .legend-color { background: #e9c46a; }
  </style>
</head>
<body>
  <div id="viewDiv"></div>
  
  <div class="control-panel">
    <h2 class="panel-title">Henge Finder</h2>
    
    <div class="info-row">
      <span class="info-label">Location</span>
      <span class="info-value" id="coords">Click on map</span>
    </div>
    
    <div class="info-row">
      <span class="info-label">Sunset</span>
      <span class="info-value" id="azimuth">--°</span>
    </div>
    <div class="info-row">
      <span class="info-label">Sunrise</span>
      <span class="info-value" id="sunrise">--°</span>
    </div>
    
    <div class="info-row">
      <span class="info-label">Direction</span>
      <div class="compass">
        <span class="compass-dir" id="dir-n">N</span>
        <span class="compass-dir" id="dir-e">E</span>
        <span class="compass-dir" id="dir-s">S</span>
        <span class="compass-dir" id="dir-w">W</span>
      </div>
    </div>
    
    <div class="slider-container">
      <label class="slider-label">Date of Year</label>
      <div class="date-display" id="dateDisplay">March 20</div>
      <input type="range" id="dateSlider" min="1" max="365" value="79">
    </div>
    
    <p class="instruction">Click anywhere on the map to set your henge location</p>
    
    <div class="legend">
      <div class="legend-item legend-sunset">
        <div class="legend-color"></div>
        <span>Sunset</span>
      </div>
      <div class="legend-item legend-sunrise">
        <div class="legend-color"></div>
        <span>Sunrise</span>
      </div>
    </div>
  </div>
  
  <script>
    require([
      "esri/Map",
      "esri/views/SceneView",
      "esri/layers/GraphicsLayer",
      "esri/Graphic",
      "esri/geometry/Point",
      "esri/geometry/Polyline",
      "esri/symbols/SimpleMarkerSymbol",
      "esri/symbols/SimpleLineSymbol"
    ], function(Map, SceneView, GraphicsLayer, Graphic, Point, Polyline, SimpleMarkerSymbol, SimpleLineSymbol) {
      
      const map = new Map({ basemap: "satellite" });
      
      const view = new SceneView({
        container: "viewDiv",
        map: map,
        center: [-100.4593, 36.9014],
        zoom: 15,
        environment: { lighting: { directShadowsEnabled: true, date: new Date() } }
      });
      
      const graphicsLayer = new GraphicsLayer();
      map.add(graphicsLayer);
      
      function getDateFromDay(dayOfYear) {
        const year = new Date().getFullYear();
        const date = new Date(year, 0);
        date.setDate(dayOfYear);
        date.setHours(18, 0, 0, 0);
        return date;
      }
      
      view.environment.lighting.date = getDateFromDay(79);
      
      let selectedLocation = null;
      let selectedDate = 79;
      
      const markerSymbol = new SimpleMarkerSymbol({
        color: "#f4a261",
        size: 12,
        outline: { color: "#f1faee", width: 2 }
      });
      
      function calculateSunsetAzimuth(latitude, dayOfYear) {
        const latRad = latitude * Math.PI / 180;
        const declination = 23.45 * Math.sin((360 / 365) * (dayOfYear - 81) * Math.PI / 180);
        const declinationRad = declination * Math.PI / 180;
        const azimuthRad = Math.acos(Math.sin(declinationRad) / Math.cos(latRad));
        let azimuth = azimuthRad * 180 / Math.PI;
        if (declinationRad > 0) azimuth = 180 - azimuth;
        return azimuth;
      }
      
      function calculateDayFromAzimuth(latitude, targetAzimuth) {
        for (let day = 1; day <= 365; day++) {
          const azimuth = calculateSunsetAzimuth(latitude, day);
          if (Math.abs(azimuth - targetAzimuth) < 0.5) return day;
        }
        const baseAzimuth = calculateSunsetAzimuth(latitude, 79);
        const offset = targetAzimuth - baseAzimuth;
        const dayOffset = (offset / 93) * 92;
        return Math.max(1, Math.min(365, 79 + Math.round(dayOffset)));
      }
      
      function getDirectionFromAzimuth(azimuth) {
        if (azimuth >= 337.5 || azimuth < 22.5) return "N";
        if (azimuth >= 22.5 && azimuth < 67.5) return "NE";
        if (azimuth >= 67.5 && azimuth < 112.5) return "E";
        if (azimuth >= 112.5 && azimuth < 157.5) return "SE";
        if (azimuth >= 157.5 && azimuth < 202.5) return "S";
        if (azimuth >= 202.5 && azimuth < 247.5) return "SW";
        if (azimuth >= 247.5 && azimuth < 292.5) return "W";
        if (azimuth >= 292.5 && azimuth < 337.5) return "NW";
        return "W";
      }
      
      function getMonthDay(dayOfYear) {
        const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
        const daysInMonth = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
        let remainingDays = dayOfYear;
        for (let i = 0; i < months.length; i++) {
          if (remainingDays <= daysInMonth[i]) return months[i] + " " + remainingDays;
          remainingDays -= daysInMonth[i];
        }
        return "December 31";
      }
      
      function updateGraphics() {
        graphicsLayer.removeAll();
        
        if (!selectedLocation) return;
        
        const latitude = selectedLocation.latitude;
        const longitude = selectedLocation.longitude;
        const sunsetAzimuth = calculateSunsetAzimuth(latitude, selectedDate);
        const sunriseAzimuth = (sunsetAzimuth + 180) % 360;
        
        const point = new Point({ longitude: longitude, latitude: latitude, spatialReference: { wkid: 4326 } });
        
        graphicsLayer.add(new Graphic({ geometry: point, symbol: markerSymbol }));
        
        const lineLength = 1.5;
        const angleSpread = 5;
        const numLines = Math.floor(angleSpread / 0.1) + 1;
        
        function drawSunLines(azimuth, color) {
          for (let i = 0; i < numLines; i++) {
            const angleOffset = -angleSpread / 2 + (i * angleSpread / (numLines - 1));
            const angle = (azimuth + angleOffset - 90) * Math.PI / 180;
            
            const endLat = latitude + lineLength * Math.cos(angle);
            const endLon = longitude + lineLength * Math.sin(angle) / Math.cos(latitude * Math.PI / 180);
            
            const line = new Polyline({
              paths: [[longitude, latitude], [endLon, endLat]],
              spatialReference: { wkid: 4326 }
            });
            
            const lineSymbol = new SimpleLineSymbol({
              color: color,
              width: 2,
              cap: "round"
            });
            
            graphicsLayer.add(new Graphic({ geometry: line, symbol: lineSymbol }));
          }
        }
        
        drawSunLines(sunsetAzimuth, [231, 111, 81]);
        drawSunLines(sunriseAzimuth, [233, 196, 106]);
        
        document.getElementById("azimuth").textContent = sunsetAzimuth.toFixed(1) + "°";
        document.getElementById("sunrise").textContent = sunriseAzimuth.toFixed(1) + "°";
        
        const direction = getDirectionFromAzimuth(sunsetAzimuth);
        document.querySelectorAll(".compass-dir").forEach(function(el) { el.classList.remove("active"); });
        if (direction.length === 1) {
          document.getElementById("dir-" + direction.toLowerCase()).classList.add("active");
        } else {
          document.getElementById("dir-" + direction.charAt(0).toLowerCase()).classList.add("active");
          document.getElementById("dir-" + direction.charAt(1).toLowerCase()).classList.add("active");
        }
      }
      
      view.on("click", function(event) {
        selectedLocation = { longitude: event.mapPoint.longitude, latitude: event.mapPoint.latitude };
        document.getElementById("coords").textContent = selectedLocation.latitude.toFixed(4) + "°, " + selectedLocation.longitude.toFixed(4) + "°";
        updateGraphics();
        updateHash();
      });
      
      function updateHash() {
        if (selectedLocation) {
          window.location.hash = selectedLocation.latitude.toFixed(6) + "," + selectedLocation.longitude.toFixed(6) + "," + selectedDate;
        }
        view.environment.lighting.date = getDateFromDay(selectedDate);
      }
      
      function loadFromHash() {
        const hash = window.location.hash.slice(1);
        if (hash) {
          const parts = hash.split(",");
          if (parts.length >= 3) {
            selectedLocation = { latitude: parseFloat(parts[0]), longitude: parseFloat(parts[1]) };
            selectedDate = parseInt(parts[2]);
            document.getElementById("dateSlider").value = selectedDate;
            document.getElementById("dateDisplay").textContent = getMonthDay(selectedDate);
            view.environment.lighting.date = getDateFromDay(selectedDate);
            view.center = [selectedLocation.longitude, selectedLocation.latitude];
            document.getElementById("coords").textContent = selectedLocation.latitude.toFixed(4) + "°, " + selectedLocation.longitude.toFixed(4) + "°";
            updateGraphics();
          }
        }
      }
      
      document.getElementById("dateSlider").addEventListener("input", function() {
        selectedDate = parseInt(this.value);
        document.getElementById("dateDisplay").textContent = getMonthDay(selectedDate);
        updateGraphics();
        updateHash();
      });
      
      document.getElementById("dateDisplay").textContent = getMonthDay(selectedDate);
      view.environment.lighting.date = getDateFromDay(selectedDate);
      
      view.when(loadFromHash);
    });
  </script>
</body>
</html>